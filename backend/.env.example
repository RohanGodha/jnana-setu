# --- LLM provider ---------------------------------------------------------
# LLM_PROVIDER: mock | anthropic | groq | gemini | deepseek | openai
#   - mock   : no key needed, deterministic answers (default; full app still works)
#   - groq   : FREE tier  -> https://console.groq.com/keys
#   - gemini : FREE tier  -> https://aistudio.google.com/apikey
#   - deepseek/openai/anthropic : paid
# Leaving the key blank forces MOCK mode regardless of provider.
LLM_PROVIDER=mock
LLM_API_KEY=
# Optional: override the provider's default models (else sensible presets are used).
GENERATOR_MODEL=
GUARD_MODEL=
# Optional: override the OpenAI-compatible base URL (else the preset is used).
LLM_BASE_URL=

# Examples:
#   Groq    -> LLM_PROVIDER=groq    LLM_API_KEY=gsk_...   (gen: llama-3.3-70b-versatile)
#   Gemini  -> LLM_PROVIDER=gemini  LLM_API_KEY=AIza...   (gen: gemini-2.0-flash)
#   DeepSeek-> LLM_PROVIDER=deepseek LLM_API_KEY=sk-...    (gen: deepseek-chat)

# Legacy / Anthropic shortcut (implies LLM_PROVIDER=anthropic if set):
ANTHROPIC_API_KEY=

# --- Vector store ---
CHROMA_PERSIST_PATH=./chroma_db

# --- Embeddings / rerank ---
# Set EMBEDDING_BACKEND=e5 for production (downloads intfloat/multilingual-e5-large).
# Set EMBEDDING_BACKEND=hash for a zero-dependency deterministic dev fallback.
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANK_ENABLED=false
RERANK_MODEL=mixedbread-ai/mxbai-rerank-large-v1

# --- Retrieval tuning ---
DENSE_TOP_K=20
SPARSE_TOP_K=20
RRF_K=60
FINAL_TOP_K=8

# --- Auth ---
JWT_SECRET=change-me-run-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# --- Tiers / limits ---
FREE_TIER_DAILY_LIMIT=3

# --- Storage ---
USER_DB_PATH=./jnana_setu.db
BOOKS_JSON=../data/books.json

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Observability (optional) ---
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=jnana-setu
SENTRY_DSN=
